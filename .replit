modules = ["bash", "nodejs-20", "python-3.12", "web"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "at-spi2-core", "atk", "cairo", "chromium", "cups", "dbus-glib", "feh", "fluxbox", "gcc-unwrapped", "gdk-pixbuf", "gitFull", "glib", "gtk3", "gtk3-x11", "libGL", "libGLU", "libdrm", "libgbm", "libxkbcommon", "mesa", "nss", "pacmanfm", "pango", "pcmanfm", "playwright-driver", "procps", "python3", "tigervnc", "unzip", "xdotool", "xorg.libX11", "xorg.libXcomposite", "xorg.libXcursor", "xorg.libXdamage", "xorg.libXext", "xorg.libXi", "xorg.libXrandr", "xorg.libXrender", "xorg.libXt", "xorg.libXtst", "xorg.xauth", "xorg.xinit", "xorg.xorgserver", "xterm", "xvfb-run", "tor", "ollama", "llama-cpp"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Hermes"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash hermes.sh"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hermes"

[[ports]]
localPort = 3000
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 3001
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 3002
externalPort = 3002
exposeLocalhost = true

[[ports]]
localPort = 3003
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 3389
externalPort = 4200

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8787
externalPort = 80
exposeLocalhost = true

