#!/bin/bash
# Sync sensitive files (from .gitignore sensitive block) with hermes-secrets private repo
# Usage: ./sync
set -euo pipefail
exec 200>/tmp/sync.lock
flock -n 200 || ( echo "Already running" ; exit 1 )

SECRETS_REPO="https://github.com/evolve-sporty-goes/hermes-secrets.git"

# --- 1. Bootstrap Authentication Token ---
PAT_FILE="/home/runner/workspace/credentials/.pat"
if [ -f "$PAT_FILE" ] && [ -s "$PAT_FILE" ]; then
    TOKEN=$(cat "$PAT_FILE")
else
    TOKEN=""
fi
[ -z "$TOKEN" ] && { echo "ERROR: no token in .pat"; exit 1; }

# --- 2. Setup Secure Temp Repo ---
TMPDIR=$(mktemp -d); trap "rm -rf $TMPDIR" EXIT
ASKPASS="$TMPDIR/git-askpass"
printf "#!/bin/bash\necho %s\n" "$TOKEN" > "$ASKPASS"
chmod +x "$ASKPASS"; export GIT_ASKPASS="$ASKPASS"

# Clone full history (no --depth 1) so we can extract accurate commit timestamps
git clone --branch main "$SECRETS_REPO" "$TMPDIR/s" 2>/dev/null || { echo "ERROR: clone failed"; exit 1; }
cd "$TMPDIR/s"

git config user.email "hermes@replit"
git config user.name "hermes-replit"

# --- 3. Sync Logic Function ---
# Arguments: $1 = local_file_path, $2 = repo_file_name
sync_file_by_history() {
    local local_file="$1"
    local repo_file="$2"

    local local_exists=0
    local repo_exists=0
    [ -f "$local_file" ] && [ -s "$local_file" ] && local_exists=1
    [ -f "$repo_file" ] && [ -s "$repo_file" ] && repo_exists=1

    # Case A: Handle Empty/Missing Files First
    if [ "$local_exists" -eq 0 ] && [ "$repo_exists" -eq 0 ]; then
        echo "LOG ($repo_file): Neither local nor repo file exists/has content. Skipping."
        return 0
    elif [ "$local_exists" -eq 0 ]; then
        echo "LOG ($repo_file): Local is empty or missing. Bootstrapping from repo..."
        cp "$repo_file" "$local_file"
        return 0
    elif [ "$repo_exists" -eq 0 ]; then
        echo "LOG ($repo_file): Repo is empty or missing. Preparing local version to push..."
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1 # Signal that repo changed
    fi

    # Case B: Both exist. Compare actual contents before dealing with times.
    if diff -q "$local_file" "$repo_file" >/dev/null 2>&1; then
        echo "OK ($repo_file): Local and Repo match perfectly."
        return 0
    fi

    # Case C: Contents differ. Evaluate history timestamps.
    # Get local file modification time (Unix epoch format)
    local local_time
    local_time=$(date -r "$local_file" +%s)

    # Get repo file last commit time (Unix epoch format)
    local repo_time
    repo_time=$(git log -1 --format=%ct -- "$repo_file" 2>/dev/null || echo 0)

    echo "Evaluating $repo_file History -> Local: $local_time | Repo: $repo_time"

    if [ "$local_time" -gt "$repo_time" ]; then
        echo "LOG ($repo_file): Local copy is newer. Updating repo..."
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1 # Flag repo as changed
    else
        echo "LOG ($repo_file): Repo copy is newer. Updating local workspace..."
        cp "$repo_file" "$local_file"
        return 0
    fi
}

# --- 4. Execute Decisions ---
repo_changed=0

# Parse sensitive block from .gitignore (lines between "# Sensitive files" and next non-indented/non-comment/non-blank line)
# Resolves bare names/paths against workspace root; expands directories to individual files.
GITIGNORE="/home/runner/workspace/.gitignore"
WORKSPACE=$(dirname "$GITIGNORE")
if [ -f "$GITIGNORE" ]; then
    in_block=0
    while IFS= read -r line; do
        if [ "$in_block" -eq 1 ]; then
            # Stop at blank lines, non-comment, or unindented lines after block starts
            [ -z "$line" ] && { in_block=0; continue; }
            [[ "$line" =~ ^[^#] ]] && { in_block=0; continue; }
            [[ "$line" =~ ^# ]] && continue  # skip comment-only lines within block
            # Strip leading/trailing whitespace and trailing slash (directory marker)
            path=$(echo "$line" | xargs)
            path="${path%/}"
            [ -z "$path" ] && continue

            # Resolve against workspace root (handle both bare names and relative paths)
            if [[ "$path" != /* ]]; then
                full_path="$WORKSPACE/$path"
            else
                full_path="$path"
            fi

            if [ -d "$full_path" ]; then
                # Expand directory: sync each file inside (non-recursive, skip hidden)
                while IFS= read -r -d '' file; do
                    repo_file=$(basename "$file")
                    sync_file_by_history "$file" "$repo_file" && s=$? || s=$?
                    [ "$s" -eq 1 ] && repo_changed=1
                done < <(find "$full_path" -maxdepth 1 -type f -name "[!.]*" -print0)
            elif [ -f "$full_path" ]; then
                repo_file=$(basename "$full_path")
                sync_file_by_history "$full_path" "$repo_file" && s=$? || s=$?
                [ "$s" -eq 1 ] && repo_changed=1
            else
                echo "WARN: '$full_path' not found, skipping"
            fi
        elif printf '%s\n' "$line" | grep -q "# Sensitive"; then
            in_block=1
        fi
    done < "$GITIGNORE"
else
    echo "WARN: .gitignore not found, skipping sensitive file sync"
fi

# --- 5. Push Secrets if Repo fell behind ---
if [ "$repo_changed" -eq 1 ]; then
    git commit -m "auto: update secrets via history sync $(date -u +%Y-%m-%dT%H:%M:%SZ)" >/dev/null 2>&1
    git push origin main 2>/dev/null && echo "OK: Secrets pushed to GitHub." || echo "WARN: Push failed."
else
    echo "OK: No remote repository updates required."
fi

# --- 6. Workspace Sync & Execution ---
echo "pushing changes to hermes-replit"
cd ~/workspace

git config user.email "hermes@replit"
git config user.name "hermes-replit"
git pull origin main

# Standard workspace tracking
git add -A
if ! git diff --cached --quiet; then
    git commit -m "auto-sync: $(date)"
    git push origin main
fi
