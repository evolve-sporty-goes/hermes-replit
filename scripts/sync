#!/bin/bash
# =============================================================================
# sync — bidirectional secrets sync + workspace commit/push
#
# Two phases:
#   1. SECRETS: sync files listed under "# Sensitive" in .gitignore between
#      the local workspace and the private `hermes-secrets` repo. Timestamp wins.
#   2. WORKSPACE: commit every changed file in the workspace to `hermes-replit`
#      (one commit per file, AI-generated message), pull first, push after.
#
# Usage: ./sync
# =============================================================================
set -uo pipefail

WORKSPACE="${WORKSPACE:-/home/runner/workspace}"
SECRETS_REPO="https://github.com/evolve-sporty-goes/hermes-secrets.git"
REPO="https://github.com/evolve-sporty-goes/hermes-replit.git"
LOCK_FILE="/tmp/sync.lock"

# --- prevent concurrent runs ---
exec 200>"$LOCK_FILE"
flock -n 200 || { echo "SKIP: another sync is running"; exit 1; }
trap 'rm -f "$LOCK_FILE"' EXIT

log() { echo "[$(date -u +%H:%M:%S)] $*"; }

# ========================
#  Phase 1 — Secrets Sync
# ========================

run_secrets_sync() {
    local token
    token=$(cat "$WORKSPACE/credentials/.pat" 2>/dev/null || true)
    if [[ -z "$token" ]]; then
        log "ERROR: no PAT in credentials/.pat"; return 1
    fi

    local tmpdir
    tmpdir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "rm -rf '$tmpdir'" RETURN

    local askpass="$tmpdir/git-askpass"
    printf '#!/bin/bash\necho %s\n' "$token" > "$askpass"
    chmod +x "$askpass"
    export GIT_ASKPASS="$askpass"

    if ! git clone --quiet --branch main "$SECRETS_REPO" "$tmpdir/s" 2>/dev/null; then
        log "ERROR: clone hermes-secrets failed"; return 1
    fi

    cd "$tmpdir/s"
    git config user.email "hermes@replit"
    git config user.name  "hermes-replit"

    local repo_changed=0

    while IFS= read -r rel; do
        [[ -z "$rel" ]] && continue
        rel="${rel%/}"                        # strip optional trailing slash
        local local_path="$WORKSPACE/$rel"

        if [[ -d "$local_path" ]]; then
            # directory entry — sync each non-dot child file
            local f
            while IFS= read -r -d '' f; do
                local child_rel="${f#$WORKSPACE/}"
                _sync_one "$f" "$child_rel" || repo_changed=1
            done < <(find "$local_path" -maxdepth 1 -type f -name '[!.]*' -print0 2>/dev/null)
        else
            # file entry (even if it doesn't exist — may need bootstrap)
            _sync_one "$local_path" "$rel" || repo_changed=1
        fi
    done < <(_sensitive_entries)

    if (( repo_changed )); then
        log "Committing secret updates…"
        git commit -m "auto: secrets sync $(date -u +%Y-%m-%dT%H:%M:%SZ)" >/dev/null 2>&1 \
            && git push --quiet origin main 2>/dev/null \
            && log "OK: secrets pushed." \
            || log "WARN: secrets push failed."
    else
        log "OK: secrets in sync."
    fi
}

_sync_one() {
    local local_file="$1"   # absolute path in workspace
    local repo_file="$2"    # relative path inside secrets repo

    mkdir -p "$(dirname "$local_file")"
    mkdir -p "$(dirname "$repo_file")"

    local local_exists=0 repo_exists=0
    [[ -s "$local_file" ]] && local_exists=1
    [[ -s "$repo_file" ]]  && repo_exists=1

    # Case A: missing/empty on both sides
    if (( !local_exists && !repo_exists )); then
        echo "  SKIP: $repo_file (nowhere)"
        return 0
    fi
    # pull from repo
    if (( !local_exists )); then
        echo "  PULL ← $repo_file (bootstrapping)"
        cp "$repo_file" "$local_file"
        return 0
    fi
    # push to repo
    if (( !repo_exists )); then
        echo "  PUSH → $repo_file (new to repo)"
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1   # signal repo_changed
    fi

    # Case B: identical
    if diff -q "$local_file" "$repo_file" >/dev/null 2>&1; then
        echo "  OK: $repo_file"
        return 0
    fi

    # Case C: resolve by timestamp
    local local_time repo_time
    local_time=$(date -r "$local_file" +%s)
    repo_time=$(git log -1 --format=%ct -- "$repo_file" 2>/dev/null || echo 0)

    if (( local_time > repo_time )); then
        echo "  PUSH → $repo_file (local newer)"
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1
    else
        echo "  PULL ← $repo_file (repo newer)"
        cp "$repo_file" "$local_file"
        return 0
    fi
}

_sensitive_entries() {
    local gi="$WORKSPACE/.gitignore"
    [[ -f "$gi" ]] || return 0
    awk '
        /^# Sensitive/ { flag=1; next }
        flag && /^#/    { next }
        flag && length  { print }
    ' "$gi"
    # normalise: strip everything after trailing " ---" comment lines and empty divider lines actually the awk already skips # lines
}

# =========================
#  Phase 2 — Workspace Push
# =========================

ai_commit_msg() {
    local f="$1"
    local diffstat
    diffstat=$(git diff --cached --stat -- "$f" 2>/dev/null | tail -1)
    local key
    key=$(grep 'API_KEY' "$WORKSPACE/credentials/openrouter_credentials.txt" 2>/dev/null | tail -1 | cut -d= -f2)
    [[ -z "$key" ]] && { _fallback_msg "$f"; return; }

    local msg
    msg=$(curl -s --max-time 10 "https://openrouter.ai/api/v1/chat/completions" \
        -H "Authorization: Bearer $key" \
        -H "Content-Type: application/json" \
        -d "$(jq -nc --arg f "$(basename "$f")" --arg d "$diffstat" \
            '{model:"owl-alpha",messages:[{role:"user",content:"Write a git commit message under 10 words for file \($f): \($d). Raw text only."}],max_tokens:40}')" \
        2>/dev/null | python3 -c "
import sys,json
try:
    t=json.load(sys.stdin)['choices'][0]['message']['content']
    print(t.strip().strip('\"').strip('\`'))
except Exception:
    sys.exit(1)
" 2>/dev/null) || msg=""

    if [[ -n "$msg" ]]; then
        echo "$msg"
    else
        _fallback_msg "$f"
    fi
}

_fallback_msg() {
    local f="$1"
    git diff --cached --numstat -- "$f" 2>/dev/null \
      | awk -F'\t' '{
          a="updated";
          if ($1>0 && $2==0) a="added";
          else if ($2>0 && $1==0) a="removed";
          printf "%s %s", a, $3
        }'
}

run_workspace_sync() {
    cd "$WORKSPACE"

    git config user.email "hermes@replit"
    git config user.name  "hermes-replit"

    log "Pulling latest…"
    git pull --quiet origin main 2>/dev/null || true

    git add -A
    if git diff --cached --quiet; then
        log "OK: workspace clean, nothing to commit."
        return 0
    fi

    local staged
    staged=$(git diff --cached --name-only)
    git reset -q

    local f m
    while IFS= read -r f; do
        git add "$f"
        m=$(ai_commit_msg "$f")
        [[ -z "$m" ]] && m="update $(basename "$f")"
        git commit -m "$m" --quiet 2>/dev/null || git commit -m "update $(basename "$f")" --quiet
        log "  committed: $m"
    done <<< "$staged"

    log "Pushing to hermes-replit…"
    if git push origin main 2>&1; then
        log "OK: workspace pushed."
    else
        log "WARN: push failed (see above)."
        return 1
    fi
}

# ========================
#  Main
# ========================
log "═══ SYNC START ═══"

log "Phase 1 — Secrets"
run_secrets_sync || true

log "Phase 2 — Workspace"
run_workspace_sync || true

log "═══ SYNC DONE ═══"
