#!/bin/bash
# Sync sensitive files (from .gitignore sensitive block) with hermes-secrets private repo
# Usage: ./sync
set -euo pipefail
exec 200>/tmp/sync.lock
flock -n 200 || ( echo "Already running" ; exit 1 )

SECRETS_REPO="https://github.com/evolve-sporty-goes/hermes-secrets.git"
REPO="https://github.com/evolve-sporty-goes/hermes-replit.git"

# Generate commit message via AI (fallback to file list)
ai_commit_msg() {
    local diffstat; diffstat=$(git diff --cached --stat | tail -1)
    local key; key=$(grep 'API_KEY' /home/runner/workspace/credentials/openrouter_credentials.txt 2>/dev/null | tail -1 | cut -d= -f2)
    [ -z "$key" ] && { git diff --cached --numstat | awk -F'	' '{a="updated";if($1>0&&$2==0)a="added";else if($2>0&&$1==0)a="removed";printf "%s %s, ",a,$3}' | sed 's/, $//'; return; }
    local msg; msg=$(curl -s --max-time 8 https://openrouter.ai/api/v1/chat/completions \
        -H "Authorization: Bearer $key" -H "Content-Type: application/json" \
        -d "{\"model\":\"owl-alpha\",\"messages\":[{\"role\":\"user\",\"content\":\"Write a git commit message under 10 words for file $(basename $f): $diffstat. Raw text only.\"}],\"max_tokens\":40}" \
        2>/dev/null | python3 -c "import sys,json; t=json.load(sys.stdin)['choices'][0]['message']['content']; print(t.strip().strip(chr(34)).strip(chr(96)))")
    [ -n "$msg" ] && echo "$msg" || echo "$diffstat"
}
# --- 1. Bootstrap Authentication Token ---
PAT_FILE="/home/runner/workspace/credentials/.pat"
if [ -f "$PAT_FILE" ] && [ -s "$PAT_FILE" ]; then
    TOKEN=$(cat "$PAT_FILE")
else
    TOKEN=""
fi
[ -z "$TOKEN" ] && { echo "ERROR: no token in .pat"; exit 1; }

# --- 2. Setup Secure Temp Repo ---
TMPDIR=$(mktemp -d); trap "rm -rf $TMPDIR" EXIT
ASKPASS="$TMPDIR/git-askpass"
printf "#!/bin/bash\necho %s\n" "$TOKEN" > "$ASKPASS"
chmod +x "$ASKPASS"; export GIT_ASKPASS="$ASKPASS"

# Clone full history (no --depth 1) so we can extract accurate commit timestamps
git clone --branch main "$SECRETS_REPO" "$TMPDIR/s" 2>/dev/null || { echo "ERROR: clone failed"; exit 1; }
cd "$TMPDIR/s"

git config user.email "hermes@replit"
git config user.name "hermes-replit"

# --- 3. Sync Logic Function ---
# Arguments: $1 = local_file_path, $2 = repo_file_name
sync_file_by_history() {
    local local_file="$1"
    local repo_file="$2"

    local local_exists=0
    local repo_exists=0
    [ -f "$local_file" ] && [ -s "$local_file" ] && local_exists=1
    [ -f "$repo_file" ] && [ -s "$repo_file" ] && repo_exists=1

    # Case A: Handle Empty/Missing Files First
    if [ "$local_exists" -eq 0 ] && [ "$repo_exists" -eq 0 ]; then
        echo "SKIP (A): $repo_file — neither local nor repo has content"
        return 0
    elif [ "$local_exists" -eq 0 ]; then
        echo "PULL (A): $repo_file ← bootstrapping from repo"
        cp "$repo_file" "$local_file"
        return 0
    elif [ "$repo_exists" -eq 0 ]; then
        echo "PUSH (A): $repo_file → repo empty, staging local"
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1
    fi

    # Case B: Both exist with same content
    if diff -q "$local_file" "$repo_file" >/dev/null 2>&1; then
        echo "OK (B): $repo_file — identical"
        return 0
    fi

    # Case C: Contents differ, compare timestamps
    local local_time repo_time
    local_time=$(date -r "$local_file" +%s)
    repo_time=$(git log -1 --format=%ct -- "$repo_file" 2>/dev/null || echo 0)

    if [ "$local_time" -gt "$repo_time" ]; then
        echo "PUSH (C): $repo_file → local newer ($local_time > $repo_time)"
        cp "$local_file" "$repo_file"
        git add "$repo_file"
        return 1
    else
        echo "PULL (C): $repo_file ← repo newer ($repo_time > $local_time)"
        cp "$repo_file" "$local_file"
        return 0
    fi
}

# --- 4. Execute Decisions ---
repo_changed=0

# Extract file list from .gitignore sensitive block, resolve to absolute paths
GITIGNORE="/home/runner/workspace/.gitignore"
WORKSPACE=$(dirname "$GITIGNORE")

if [ -f "$GITIGNORE" ]; then
    # Extract entries from sensitive block: after "# Sensitive" line, skip comment lines, stop at EOF/blank
    file_list=$(awk 'BEGIN{flag=0} /# Sensitive/{flag=1; next} flag==1{ if(substr($0,1,1)=="#") next; if(length($0)>0) print}' "$GITIGNORE")
    
    while IFS= read -r entry; do
        entry="${entry%/}"  # strip trailing slash
        [[ "$entry" != /* ]] && entry="$WORKSPACE/$entry"
        
        if [ -d "$entry" ]; then
            while IFS= read -r -d '' file; do
                sync_file_by_history "$file" "$(basename "$file")" && s=$? || s=$?
                [ "$s" -eq 1 ] && repo_changed=1
            done < <(find "$entry" -maxdepth 1 -type f -name "[!.]*" -print0)
        elif [ -f "$entry" ]; then
            sync_file_by_history "$entry" "$(basename "$entry")" && s=$? || s=$?
            [ "$s" -eq 1 ] && repo_changed=1
        else
            echo "WARN: '$entry' not found, skipping"
        fi
    done <<< "$file_list"
else
    echo "WARN: .gitignore not found, skipping sensitive file sync"
fi

# --- 5. Push Secrets if Repo fell behind ---
if [ "$repo_changed" -eq 1 ]; then
    git commit -m "auto: update secrets via history sync $(date -u +%Y-%m-%dT%H:%M:%SZ)" >/dev/null 2>&1
    git push origin main 2>/dev/null && echo "OK: Secrets pushed to GitHub." || echo "WARN: Push failed."
else
    echo "OK: No remote repository updates required."
fi

# --- 6. Workspace Sync & Execution ---
echo "pushing changes to hermes-replit"
cd ~/workspace

git config user.email "hermes@replit"
git config user.name "hermes-replit"
git pull origin main

# Standard workspace tracking — commit per file with AI message
git add -A
if ! git diff --cached --quiet; then
    staged=$(git diff --cached --name-only)
    git reset -q
    while IFS= read -r f; do
        git add "$f"
        m=$(ai_commit_msg)
        git commit -m "$m" 2>/dev/null || git commit -m "update $(basename $f)"
    done <<< "$staged"

    # Attempt push; if blocked by secret scanning, strip from history and force-push
    push_output=$(git push origin main 2>&1) || {
        echo "$push_output"

        # Extract file paths from push protection error (pattern: "path: <filepath>:<line>")
        blocked_files=$(echo "$push_output" | grep -oP 'path:\s+\K\S+' | cut -d: -f1 | sort -u)

        if [ -n "$blocked_files" ]; then
            echo "SECRET BLOCK detected. Stripping from history:"

            filter_paths=()
            while IFS= read -r blocked_file; do
                [ -z "$blocked_file" ] && continue
                rel_path="${blocked_file#$WORKSPACE/}"

                # Add to .gitignore (prevent recurrence)
                if ! grep -qF "$rel_path" "$GITIGNORE" 2>/dev/null; then
                    echo "$rel_path" >> "$GITIGNORE"
                    echo "  + gitignore: $rel_path"
                fi

                filter_paths+=(--path "$rel_path")
            done <<< "$blocked_files"

            # Strip all blocked paths from history in one pass
            git filter-repo "${filter_paths[@]}" --invert-paths --force

            # Re-add origin (filter-repo removes it)
            git remote add origin "$REPO" 2>/dev/null || true

            # Stage .gitignore changes
            git add "$GITIGNORE"
            git diff --cached --quiet || git commit -m "auto: add secret-blocked files to gitignore"

            # Force-push rewritten history
            echo "Force-pushing..."
            git push --force origin main 2>&1 || echo "WARN: Force push failed."
        else
            echo "WARN: Push failed but no secret paths detected in output."
        fi
    }
fi
