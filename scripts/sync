#!/bin/bash
# sync — bidirectional secrets sync + workspace commit/push
set -uo pipefail

WORKSPACE="${WORKSPACE:-/home/runner/workspace}"
SECRETS_REPO="https://github.com/evolve-sporty-goes/hermes-secrets.git"
LOG_TS() { echo "[$(date -u +%H:%M:%S)]"; }

# --- lock (auto-released when FD closes on exit) ---
exec 9>/tmp/sync.lock
flock -n 9 || { echo "$(LOG_TS) SKIP: already running"; exit 1; }

# --- auth (PAT is askpass for both phases) ---
TOKEN=$(cat "$WORKSPACE/credentials/.pat" 2>/dev/null) || true
[[ -z "$TOKEN" ]] && { echo "$(LOG_TS) ERROR: empty .pat"; exit 1; }
ASKPASS=$(mktemp -u)
printf '#!/bin/sh\necho %s\n' "$TOKEN" > "$ASKPASS"
chmod +x "$ASKPASS"
export GIT_ASKPASS="$ASKPASS"
trap 'rm -f "$ASKPASS"' EXIT

# --- secrets sync ---
SECRETS_DIR=$(mktemp -d)
trap 'rm -f "$ASKPASS"; rm -rf "$SECRETS_DIR"' EXIT
git clone --quiet --branch main "$SECRETS_REPO" "$SECRETS_DIR/repo" 2>/dev/null \
  || { echo "$(LOG_TS) ERROR: clone secrets"; exit 1; }
cd "$SECRETS_DIR/repo"
git config user.email "hermes@replit"
git config user.name  "hermes-replit"

_sync_one() {
  local lf="$1" rf="$2"
  mkdir -p "$(dirname "$lf")" "$(dirname "$rf")"
  local le=0 re=0
  [[ -s "$lf" ]] && le=1
  [[ -s "$rf" ]] && re=1
  (( !le && !re )) && { echo "  SKIP $rf"; return 0; }
  if (( !le )); then echo "  PULL ← $rf"; cp "$rf" "$lf"; return 0; fi
  if (( !re )); then echo "  PUSH → $rf"; cp "$lf" "$rf"; git add "$rf"; return 1; fi
  diff -q "$lf" "$rf" >/dev/null 2>&1 && { echo "  OK $rf"; return 0; }
  local lt rt; lt=$(date -r "$lf" +%s); rt=$(git log -1 --format=%ct -- "$rf" 2>/dev/null || echo 0)
  if (( lt > rt )); then echo "  PUSH → $rf (newer)"; cp "$lf" "$rf"; git add "$rf"; return 1;
  else echo "  PULL ← $rf (newer)"; cp "$rf" "$lf"; return 0; fi
}

echo "$(LOG_TS) ═══ PHASE 1: secrets ═══"
changed=0
entries=$(awk '/^# Sensitive/{f=1;next} f&&/^#/{next} f&&/^---/{next} f&&length{print}' "$WORKSPACE/.gitignore")
while IFS= read -r rel; do
  [[ -z "$rel" ]] && continue
  rel="${rel%/}"
  local_path="$WORKSPACE/$rel"
  if [[ -d "$local_path" ]]; then
    while IFS= read -r -d '' f; do
      child_rel="${f#$WORKSPACE/}"
      _sync_one "$f" "$child_rel" || changed=1
    done < <(find "$local_path" -maxdepth 1 -type f -name '[!.]*' -print0 2>/dev/null)
  else
    _sync_one "$local_path" "$rel" || changed=1
  fi
done <<< "$entries"

if (( changed )); then
  git commit -m "auto: secrets sync $(date -u +%Y-%m-%dT%H:%M:%SZ)" --quiet \
    && git push --quiet origin main 2>/dev/null \
    && echo "$(LOG_TS) OK: secrets pushed" \
    || echo "$(LOG_TS) WARN: secrets push failed"
else
  echo "$(LOG_TS) OK: secrets in sync"
fi

# --- workspace push ---
echo "$(LOG_TS) ═══ PHASE 2: workspace ═══"
cd "$WORKSPACE"
git config user.email "hermes@replit"
git config user.name  "hermes-replit"
GIT_ASKPASS="$ASKPASS" git pull --quiet --rebase origin main 2>/dev/null || true

git add -A
if git diff --cached --quiet; then
  echo "$(LOG_TS) OK: workspace clean"
  echo "$(LOG_TS) ═══ SYNC DONE ═══"
  return 0 2>/dev/null || exit 0
fi

staged=$(git diff --cached --name-only)
git reset -q
msg="auto: $(date -u +%Y-%m-%dT%H:%M:%SZ) — $(echo "$staged" | wc -l) file(s): $(echo "$staged" | tr '\n' ' ')"
git add -A
git commit -m "$msg" --quiet

if GIT_ASKPASS="$ASKPASS" git push --quiet origin main 2>/dev/null; then
  echo "$(LOG_TS) OK: workspace pushed"
else
  # Secret rule violation — GitHub rejects the push and names the offending file(s)
  push_err=$(GIT_ASKPASS="$ASKPASS" git push origin main 2>&1 || true)
  blocked=$(echo "$push_err" | grep -oP 'path:\s+\K\S+' | cut -d: -f1 | sort -u)
  if [[ -z "$blocked" ]]; then
    echo "$(LOG_TS) WARN: push failed (no secret paths detected)"
    echo "$push_err" | head -5
  else
    echo "$(LOG_TS) SECRET BLOCK — adding to .gitignore sensitive block, stripping commit"
    git reset --quiet HEAD~1   # unstage the commit, keep working tree
    for p in $blocked; do
      rel="${p#$WORKSPACE/}"
      [[ -z "$rel" ]] && rel="$p"
      # append to sensitive block
      grep -qxF "$rel" "$WORKSPACE/.gitignore" 2>/dev/null \
        || echo "$rel" >> "$WORKSPACE/.gitignore"
      echo "  + gitignore: $rel"
    done
    git add -A
    new_msg="auto: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    if git diff --cached --quiet; then
      echo "$(LOG_TS) commit now empty after stripping blocked files; nothing to push"
    else
      git commit -m "$new_msg" --quiet \
        && GIT_ASKPASS="$ASKPASS" git push --quiet origin main 2>/dev/null \
        && echo "$(LOG_TS) OK: re-pushed (blocked files excluded)" \
        || echo "$(LOG_TS) WARN: re-push still failed"
    fi
  fi
fi

echo "$(LOG_TS) ═══ SYNC DONE ═══"
