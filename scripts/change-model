#!/usr/bin/env bash
set -euo pipefail

CRED="${WORKSPACE:-$HOME/workspace}/credentials/cloudflare.txt"
mkdir -p "$(dirname "$CRED")"
touch "$CRED"

[[ $# -ge 2 ]] && printf 'ACCOUNT_ID=%s\nAPI_KEY=%s\nEMAIL=%s\nPASSWORD=%s\n\n' "$1" "$2" "${3:-fake@duck.com}" "${4:-fakepass123}" >> "$CRED"

# Read blank-line-separated blocks as NUL-delimited array, keeping cfut_ keys only.
mapfile -t -d '' BLOCKS < <(awk -v RS='' -v ORS='\0' '$0 ~ /API_KEY=cfut_/' "$CRED")
N=${#BLOCKS[@]}
(( N == 0 )) && { echo "No valid credentials"; exit 1; }

# Shuffle blocks.
for ((i = N - 1; i > 0; i--)); do
  j=$((RANDOM % (i + 1)))
  t=${BLOCKS[$i]}; BLOCKS[$i]=${BLOCKS[$j]}; BLOCKS[$j]=$t
done

printf '%s\n\n' "${BLOCKS[@]}" > "$CRED"

A=$(awk -F= '/^ACCOUNT_ID=/{print $2}' <<<"${BLOCKS[0]}" | xargs)
K=$(awk -F= '/^API_KEY=/{print $2}' <<<"${BLOCKS[0]}" | xargs)

echo "Using account: ${A:0:8}... ($N total)"

hermes config set model.provider custom
hermes config set model.base_url "https://api.cloudflare.com/client/v4/accounts/$A/ai/v1"
hermes config set model.api_key "$K"
hermes config set model.api_compat openai
hermes config set model.default "@cf/moonshotai/kimi-k2.7-code"
hermes config set model.display_name "cloudflare"

