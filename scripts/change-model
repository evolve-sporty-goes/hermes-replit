#!/usr/bin/env bash
set -euo pipefail

CRED="${WORKSPACE:-$HOME/workspace}/credentials/cloudflare.txt"
mkdir -p "$(dirname "$CRED")"
touch "$CRED"

[[ $# -ge 2 ]] && printf 'ACCOUNT_ID=%s\nAPI_KEY=%s\n\n' "$1" "$2" >> "$CRED"

mapfile -t ACCT < <(grep '^ACCOUNT_ID=' "$CRED" | cut -d= -f2-)
mapfile -t KEY  < <(grep '^API_KEY='  "$CRED" | cut -d= -f2-)
N=${#ACCT[@]}

(( N == 0 )) && { echo "No credentials"; exit 1; }
(( N == ${#KEY[@]} )) || { echo "Mismatched keys"; exit 1; }

I=$((RANDOM % N))
A=${ACCT[$I]//[[:space:]]/}
K=${KEY[$I]//[[:space:]]/}

echo "Using account: ${A:0:8}..."

hermes config set model.provider custom
hermes config set model.base_url "https://api.cloudflare.com/client/v4/accounts/$A/ai/v1"
hermes config set model.api_key "$K"
hermes config set model.api_compat openai
hermes config set model.default "@cf/moonshotai/kimi-k2.7-code"
hermes config set model.display_name "cloudflare"

cloudflare_signup.sh
sync

SCRIPT=$(realpath "$0")
LOG_DIR="$HOME/.hermes_data/logs"
LOG="$LOG_DIR/agent.log"
PIDFILE="/tmp/hermes-watcher.pid"

[[ -f "$PIDFILE" ]] && { kill "$(cat "$PIDFILE")" 2>/dev/null || true; sleep 0.5; rm -f "$PIDFILE"; }

mkdir -p "$LOG_DIR"
> "$LOG"

(
  tail -F -n 0 "$LOG" 2>/dev/null |
    grep -q "HTTP 429" && "$SCRIPT" &
) >/dev/null 2>&1 &
echo "$!" > "$PIDFILE"
disown 2>/dev/null || true

echo "Done. watcher PID: $(cat "$PIDFILE")"