#!/usr/bin/env bash
CRED="${WORKSPACE:-$HOME/workspace}/credentials/cloudflare.txt"
mkdir -p "$(dirname "$CRED")"
touch "$CRED"

if [[ $# -ge 2 ]]; then
  printf 'ACCOUNT_ID=%s\nAPI_KEY=%s\n\n' "$1" "$2" >> "$CRED"
  echo "Added: ${1:0:8}..."
fi

[[ -f "$CRED" ]] || { echo "No $CRED"; exit 1; }

# Extract ACCOUNT_ID and API_KEY lines separately, then pick the SAME index.
mapfile -t ACCT < <(grep '^ACCOUNT_ID=' "$CRED")
mapfile -t KEY  < <(grep '^API_KEY='  "$CRED")

N=${#ACCT[@]}
if (( N == 0 )); then
  echo "No credentials in $CRED" >&2
  exit 1
fi
if (( N != ${#KEY[@]} )); then
  echo "Mismatched ACCOUNT_ID/API_KEY count in $CRED" >&2
  exit 1
fi

I=$((RANDOM % N))

# Use cut -f2- so values containing '=' are not truncated
A=$(printf '%s' "${ACCT[$I]}" | cut -d= -f2-)
K=$(printf '%s' "${KEY[$I]}"  | cut -d= -f2-)

# Trim whitespace
A=$(printf '%s' "$A" | xargs)
K=$(printf '%s' "$K" | xargs)

U="https://api.cloudflare.com/client/v4/accounts/${A}/ai/v1"

echo "Using account: ${A:0:8}... key: ${K:0:8}..."
hermes config set model.provider custom
hermes config set model.base_url "$U"
hermes config set model.api_key "$K"
hermes config set model.api_compat openai
hermes config set model.default "@cf/moonshotai/kimi-k2.7-code"
hermes config set model.display_name "cloudflare"
cloudflare_signup.sh
sync

# --- self-contained watcher (unchanged) ---
SCRIPT="$(realpath "$0")"
LOG="$HOME/.hermes_data/logs/errors.log"
PIDFILE="/tmp/hermes-watcher.pid"

if [[ -f "$PIDFILE" ]]; then
  OLD_PID=$(cat "$PIDFILE")
  if kill -0 "$OLD_PID" 2>/dev/null; then
    kill "$OLD_PID" 2>/dev/null || true
    sleep 0.5
  fi
  rm -f "$PIDFILE"
fi

mkdir -p "$(dirname "$LOG")"
touch "$LOG"

(
  tail -F -n 0 "$LOG" 2>/dev/null | while read -r line; do
    if echo "$line" | grep -q "HTTP 429"; then
      "$SCRIPT" &
      break
    fi
  done
) >/dev/null 2>&1 &

NEW_PID=$!
echo "$NEW_PID" > "$PIDFILE"
disown "$NEW_PID" 2>/dev/null || true

echo "Done. watcher PID: $NEW_PID"
Key points:

grep '^ACCOUNT_ID=' and grep '^API_KEY=' ignore blank lines, comments, or unrelated values.
ACCT[$I] and KEY[$I] always share the same index, so $A belongs to $K.
cut -d= -f2- preserves any = characters inside the value.
xargs trims accidental leading/trailing whitespace.
Security note: you pasted live credentials in this chat; consider them exposed and rotate the API token and password. Also ensure automated account creation complies with Cloudflare's Terms of Service.

